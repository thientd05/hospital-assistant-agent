# === apps/api (REST) ===
MONGODB_URI=mongodb://localhost:27017        # prod: chuỗi kết nối MongoDB Atlas (mongodb+srv://...)
JWT_SECRET=change-me-please-use-a-long-random-string   # PHẢI giống nhau giữa api & agent

# === apps/agent ===
ANTHROPIC_API_KEY=sk-ant-...
API_URL=http://localhost:3001                # prod: URL Vercel của apps/api

# === cả api & agent (CORS) ===
CORS_ORIGIN=http://localhost:3000            # prod: URL Vercel của web (không có dấu / cuối)
