{
  "name": "@pr_hospitalagent/agent",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file-if-exists=../../.env --experimental-strip-types src/index.ts",
    "start": "node --experimental-strip-types src/index.ts",
    "vercel-build": "esbuild src/app.ts --bundle --platform=node --format=esm --outfile=dist/app.js --external:fastify --external:@fastify/* --external:@anthropic-ai/sdk --external:zod && cp src/agent/config.json dist/config.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@fastify/cors": "^10",
    "@fastify/jwt": "^10.0.0",
    "fastify": "^5",
    "zod": "^3"
  },
  "devDependencies": {
    "@pr_hospitalagent/types": "workspace:*",
    "esbuild": "^0.25.0",
    "typescript": "^5"
  }
}
